# PANEL WEB example environment
# Copy to .env.local for local development or to .env on the VPS.

# Database
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=change_me
DB_PASS=change_me
DB_NAME=programm_panel
DB_SCHEMA=

# Legacy server probes
# Set to 0 during migrations or when diagnosing internal node issues.
LEGACY_SERVER_PROBES_ENABLED=1

# Used only by tools/bootstrap_admin.php
BOOTSTRAP_ADMIN_USER=owner
BOOTSTRAP_ADMIN_PASS=ChangeMe123!
BOOTSTRAP_ADMIN_EMAIL=owner@example.com
BOOTSTRAP_ADMIN_NAME=Project Owner
